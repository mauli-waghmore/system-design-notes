      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Then qualify",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Then qualify",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-925095",
      "type": "text",
      "x": 1099,
      "y": 3396,
      "width": 397,
      "height": 159,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
