      "updated": 0,
      "link": null,
      "locked": false,
      "text": "5. Durability overhead",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "5. Durability overhead",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-925040",
      "type": "text",
      "x": 599,
      "y": 1541,
      "width": 382,
      "height": 164,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
