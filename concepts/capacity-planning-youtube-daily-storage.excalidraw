      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Some videos may be deleted,\nblocked, deduplicated, or moved\nto cold tiers.\n\nEstimate gross new storage first.",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Some videos may be deleted,\nblocked, deduplicated, or moved\nto cold tiers.\n\nEstimate gross new storage first.",
