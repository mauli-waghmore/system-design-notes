      "version": 1,
      "versionNonce": 927037,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "YouTube stores more than\none uploaded file.\n\nVideos become multiple renditions:\n144p, 360p, 720p, 1080p, audio.",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "YouTube stores more than\none uploaded file.\n\nVideos become multiple renditions:\n144p, 360p, 720p, 1080p, audio.",
      "lineHeight": 1.25,
      "baseline": 159
    },
