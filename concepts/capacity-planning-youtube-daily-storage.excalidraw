      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Mental model",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Mental model",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-925022",
      "type": "text",
      "x": 874,
      "y": 481,
      "width": 612,
      "height": 144,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-925001",
      "roundness": null,
      "seed": 926022,
      "version": 1,
      "versionNonce": 927022,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Think like a warehouse planner.\nNew boxes arrive every minute.\nEach box has a size. The warehouse\nkeeps extra copies for durability.",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Think like a warehouse planner.\nNew boxes arrive every minute.\nEach box has a size. The warehouse\nkeeps extra copies for durability.",
      "lineHeight": 1.25,
      "baseline": 139
    },
    {
      "id": "text-925023",
      "type": "text",
      "x": 95,
      "y": 705,
      "width": 1200,
      "height": 52,
      "angle": 0,
      "strokeColor": "#2b8a3e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-925001",
      "roundness": null,
      "seed": 926023,
      "version": 1,
      "versionNonce": 927023,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Main takeaway: 500 hours/minute becomes 720,000 video-hours/day.\nWith realistic encoding and durability assumptions, that is several PB/day.",
      "fontSize": 20,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Main takeaway: 500 hours/minute becomes 720,000 video-hours/day.\nWith realistic encoding and durability assumptions, that is several PB/day.",
      "lineHeight": 1.25,
      "baseline": 47
    },
    {
      "id": "text-925024",
      "type": "text",
      "x": 95,
      "y": 1015,
      "width": 1020,
      "height": 46,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-925002",
      "roundness": null,
      "seed": 926024,
      "version": 1,
      "versionNonce": 927024,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Start With Assumptions, Not Magic Numbers",
      "fontSize": 36,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Start With Assumptions, Not Magic Numbers",
      "lineHeight": 1.25,
      "baseline": 41
    },
    {
      "id": "text-925025",
