      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "1 day = 24 hours\n1 hour = 60 minutes\n\nHours/day = 500 x 60 x 24\n= 720,000 video-hours/day",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1 day = 24 hours\n1 hour = 60 minutes\n\nHours/day = 500 x 60 x 24\n= 720,000 video-hours/day",
      "lineHeight": 1.25,
      "baseline": 159
    },
