      "roundness": null,
      "seed": 926040,
      "version": 1,
      "versionNonce": 927040,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Production storage must survive\nmachine and disk failures.\n\nReplication or erasure coding\nadds extra storage overhead.",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Production storage must survive\nmachine and disk failures.\n\nReplication or erasure coding\nadds extra storage overhead.",
      "lineHeight": 1.25,
      "baseline": 159
    },
