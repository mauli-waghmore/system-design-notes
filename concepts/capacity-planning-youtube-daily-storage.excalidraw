      "seed": 926025,
      "version": 1,
      "versionNonce": 927025,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Every estimate should say where the number came from,\nor that it is an explicit assumption.",
      "fontSize": 18,
      "fontFamily": 3,
      "textAlign": "left",
