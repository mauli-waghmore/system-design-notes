      "roundness": null,
      "seed": 926095,
      "version": 1,
      "versionNonce": 927095,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Mention:\n- Codec mix changes answer\n- Multiple renditions add storage\n- Dedup/deletion can reduce growth\n- Cold storage is cheaper\n- CDN copies support hot videos",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Mention:\n- Codec mix changes answer\n- Multiple renditions add storage\n- Dedup/deletion can reduce growth\n- Cold storage is cheaper\n- CDN copies support hot videos",
      "lineHeight": 1.25,
      "baseline": 154
    },
