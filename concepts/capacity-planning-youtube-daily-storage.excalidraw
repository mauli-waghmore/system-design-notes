      "version": 1,
      "versionNonce": 927091,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Then calculate",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Then calculate",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-925092",
      "type": "text",
      "x": 609,
      "y": 3396,
      "width": 397,
      "height": 159,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-925004",
      "roundness": null,
      "seed": 926092,
      "version": 1,
      "versionNonce": 927092,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Say:\n- Upload rate: 500 h/min\n- Daily hours: 720k h/day\n- Avg stored size: scenario\n- Overhead: durability factor\n\nKeep units visible.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Say:\n- Upload rate: 500 h/min\n- Daily hours: 720k h/day\n- Avg stored size: scenario\n- Overhead: durability factor\n\nKeep units visible.",
      "lineHeight": 1.25,
      "baseline": 154
    },
    {
