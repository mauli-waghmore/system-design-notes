      "roundness": null,
      "seed": 926084,
      "version": 1,
      "versionNonce": 927084,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Interview-safe answer: YouTube likely adds several PB/day.\nA broad estimate is roughly 2-20+ PB/day before cleanup.",
      "fontSize": 19,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Interview-safe answer: YouTube likely adds several PB/day.\nA broad estimate is roughly 2-20+ PB/day before cleanup.",
      "lineHeight": 1.25,
      "baseline": 45
    },
    {
      "id": "text-925085",
      "type": "text",
      "x": 95,
      "y": 3185,
      "width": 900,
      "height": 46,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-925004",
      "roundness": null,
      "seed": 926085,
      "version": 1,
      "versionNonce": 927085,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "How To Explain This In An Interview",
      "fontSize": 36,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "How To Explain This In An Interview",
      "lineHeight": 1.25,
      "baseline": 41
    },
    {
      "id": "text-925086",
      "type": "text",
      "x": 98,
      "y": 3245,
      "width": 900,
      "height": 44,
      "angle": 0,
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-925004",
      "roundness": null,
      "seed": 926086,
      "version": 1,
      "versionNonce": 927086,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "The interviewer cares about assumptions, units, and trade-offs,\nnot a fake exact YouTube number.",
      "fontSize": 18,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The interviewer cares about assumptions, units, and trade-offs,\nnot a fake exact YouTube number.",
      "lineHeight": 1.25,
      "baseline": 39
    },
    {
      "id": "rectangle-925087",
      "type": "rectangle",
      "x": 95,
      "y": 3330,
      "width": 445,
      "height": 245,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#e7f5ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-925004",
      "roundness": {
        "type": 3
      },
      "seed": 926087,
      "version": 1,
      "versionNonce": 927087,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false
    },
    {
      "id": "text-925088",
      "type": "text",
      "x": 119,
      "y": 3352,
      "width": 397,
      "height": 27.5,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-925004",
      "roundness": null,
      "seed": 926088,
      "version": 1,
      "versionNonce": 927088,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Clarify first",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Clarify first",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-925089",
      "type": "text",
      "x": 119,
      "y": 3396,
      "width": 397,
      "height": 159,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-925004",
      "roundness": null,
      "seed": 926089,
      "version": 1,
      "versionNonce": 927089,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Ask:\n- Raw upload or encoded outputs?\n- Include replicas / erasure coding?\n- Include thumbnails and metadata?\n- Gross ingest or net retained data?",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Ask:\n- Raw upload or encoded outputs?\n- Include replicas / erasure coding?\n- Include thumbnails and metadata?\n- Gross ingest or net retained data?",
      "lineHeight": 1.25,
      "baseline": 154
    },
    {
      "id": "rectangle-925090",
      "type": "rectangle",
      "x": 585,
      "y": 3330,
      "width": 445,
      "height": 245,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#ebfbee",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-925004",
      "roundness": {
        "type": 3
      },
      "seed": 926090,
      "version": 1,
      "versionNonce": 927090,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false
    },
    {
      "id": "text-925091",
      "type": "text",
      "x": 609,
      "y": 3352,
      "width": 397,
      "height": 27.5,
      "angle": 0,
