      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "One-line idea",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "One-line idea",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-925019",
      "type": "text",
      "x": 119,
      "y": 481,
      "width": 612,
      "height": 144,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-925001",
      "roundness": null,
      "seed": 926019,
      "version": 1,
      "versionNonce": 927019,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Daily storage = upload rate x time\nx average stored size x overhead.\n\nThe final number is less important\nthan clear assumptions and units.",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Daily storage = upload rate x time\nx average stored size x overhead.\n\nThe final number is less important\nthan clear assumptions and units.",
      "lineHeight": 1.25,
      "baseline": 139
    },
    {
