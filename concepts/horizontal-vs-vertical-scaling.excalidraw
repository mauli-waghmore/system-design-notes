      "baseline": 22
    },
    {
      "id": "text-700081",
      "type": "text",
      "x": 119,
      "y": 3041,
      "width": 600,
      "height": 100,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-700004",
      "roundness": null,
      "seed": 701081,
      "version": 2,
      "versionNonce": 1224921921,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782214965924,
      "link": null,
      "locked": false,
      "text": "- Vertical: simple, but limited by machine size\n- Horizontal: scalable, but adds distributed complexity\n- Vertical: easier data consistency\n- Horizontal: needs stateless services and load balancing\n- Horizontal: improves availability if instances are independent",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Vertical: simple, but limited by machine size\n- Horizontal: scalable, but adds distributed complexity\n- Vertical: easier data consistency\n- Horizontal: needs stateless services and load balancing\n- Horizontal: improves availability if instances are independent",
      "lineHeight": 1.25,
      "baseline": 96
    },
