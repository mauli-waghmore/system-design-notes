      "isDeleted": false,
      "boundElements": null,
      "updated": 1782214965924,
      "link": null,
      "locked": false,
      "text": "- Saying horizontal is always better\n- Ignoring database bottlenecks\n- Scaling app servers but keeping local sessions\n- Forgetting load balancer health checks\n- Not measuring before scaling",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Saying horizontal is always better\n- Ignoring database bottlenecks\n- Scaling app servers but keeping local sessions\n- Forgetting load balancer health checks\n- Not measuring before scaling",
      "lineHeight": 1.25,
      "baseline": 96
    },
