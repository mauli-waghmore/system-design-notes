    },
    {
      "id": "text-700022",
      "type": "text",
      "x": 834,
      "y": 466,
      "width": 545.5078125,
      "height": 71.25,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-700001",
      "roundness": null,
      "seed": 701022,
      "version": 2,
      "versionNonce": 760465761,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782214965920,
      "link": null,
      "locked": false,
      "text": "Vertical scaling is moving to a bigger apartment.\nHorizontal scaling is opening more apartments\nand routing people to available rooms.",
      "fontSize": 19,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Vertical scaling is moving to a bigger apartment.\nHorizontal scaling is opening more apartments\nand routing people to available rooms.",
      "lineHeight": 1.25,
      "baseline": 66
    },
    {
      "id": "text-700023",
      "type": "text",
      "x": 95,
      "y": 685,
      "width": 843.75,
      "height": 50,
      "angle": 0,
      "strokeColor": "#2b8a3e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-700001",
      "roundness": null,
      "seed": 701023,
      "version": 2,
      "versionNonce": 1504753967,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782214965920,
      "link": null,
      "locked": false,
      "text": "Main takeaway: scale up first when the system is simple;\nscale out when one machine becomes a bottleneck or availability matters.",
      "fontSize": 20,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Main takeaway: scale up first when the system is simple;\nscale out when one machine becomes a bottleneck or availability matters.",
      "lineHeight": 1.25,
      "baseline": 45
    },
