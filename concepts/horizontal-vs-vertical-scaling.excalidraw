      "isDeleted": false,
      "boundElements": null,
      "updated": 1782214965920,
      "link": null,
      "locked": false,
      "text": "Vertical scaling means making one machine stronger.\nHorizontal scaling means adding more machines\nand spreading traffic across them.",
      "fontSize": 19,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Vertical scaling means making one machine stronger.\nHorizontal scaling means adding more machines\nand spreading traffic across them.",
      "lineHeight": 1.25,
      "baseline": 66
    },
