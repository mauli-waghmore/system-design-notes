      "text": "Mental model",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Mental model",
      "lineHeight": 1.25,
      "baseline": 22
    },
    {
      "id": "text-500022",
      "type": "text",
      "x": 834,
      "y": 461,
      "width": 556.640625,
      "height": 71.25,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-500001",
      "roundness": null,
      "seed": 501022,
      "version": 2,
      "versionNonce": 1681946703,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782061292873,
      "link": null,
      "locked": false,
      "text": "Think of it like planning a city:\nroads for traffic, utilities for shared resources,\nemergency plans for failure, and room for growth.",
      "fontSize": 19,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Think of it like planning a city:\nroads for traffic, utilities for shared resources,\nemergency plans for failure, and room for growth.",
      "lineHeight": 1.25,
      "baseline": 66
    },
    {
      "id": "text-500023",
      "type": "text",
      "x": 95,
      "y": 680,
      "width": 873.6328125,
      "height": 52.5,
      "angle": 0,
      "strokeColor": "#2b8a3e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-500001",
      "roundness": null,
      "seed": 501023,
      "version": 2,
      "versionNonce": 1482504225,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782061292873,
      "link": null,
      "locked": false,
      "text": "Main takeaway: start simple, understand requirements, find bottlenecks,\nthen add complexity only where needed.",
      "fontSize": 21,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Main takeaway: start simple, understand requirements, find bottlenecks,\nthen add complexity only where needed.",
      "lineHeight": 1.25,
      "baseline": 47
    },
