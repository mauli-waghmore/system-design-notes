      "link": null,
      "locked": false,
      "text": "System design is not about naming technologies.\nIt is about explaining choices and consequences clearly.",
      "fontSize": 19,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "System design is not about naming technologies.\nIt is about explaining choices and consequences clearly.",
      "lineHeight": 1.25,
      "baseline": 42
    },
