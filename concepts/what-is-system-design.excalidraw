    },
    {
      "id": "text-500019",
      "type": "text",
      "x": 119,
      "y": 461,
      "width": 523.2421875,
      "height": 71.25,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-500001",
      "roundness": null,
      "seed": 501019,
      "version": 2,
      "versionNonce": 1908741679,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782061292873,
      "link": null,
      "locked": false,
      "text": "System design decides how clients, services,\ndata stores, caches, queues, and infrastructure\nwork together under real-world load.",
      "fontSize": 19,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "System design decides how clients, services,\ndata stores, caches, queues, and infrastructure\nwork together under real-world load.",
      "lineHeight": 1.25,
      "baseline": 66
    },
