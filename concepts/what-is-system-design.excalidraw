      "link": null,
      "locked": false,
      "text": "Common trade-offs",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Common trade-offs",
      "lineHeight": 1.25,
      "baseline": 22
    },
    {
      "id": "text-500081",
      "type": "text",
      "x": 119,
      "y": 2961,
      "width": 600,
      "height": 80,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-500004",
      "roundness": null,
      "seed": 501081,
      "version": 2,
      "versionNonce": 1526727137,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782061292875,
      "link": null,
      "locked": false,
      "text": "- Cache: faster reads, but stale data risk\n- Replication: better availability, but consistency gets harder\n- Microservices: independent scaling, but operations get complex\n- SQL: strong structure, but not perfect for every scale pattern",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Cache: faster reads, but stale data risk\n- Replication: better availability, but consistency gets harder\n- Microservices: independent scaling, but operations get complex\n- SQL: strong structure, but not perfect for every scale pattern",
      "lineHeight": 1.25,
      "baseline": 76
    },
