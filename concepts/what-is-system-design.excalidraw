    {
      "id": "text-500084",
      "type": "text",
      "x": 854,
      "y": 2961,
      "width": 506.25,
      "height": 100,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-500004",
      "roundness": null,
      "seed": 501084,
      "version": 2,
      "versionNonce": 1850154433,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782061292875,
      "link": null,
      "locked": false,
      "text": "- Jumping to tools before requirements\n- Making version one too complex\n- Ignoring failure modes\n- Forgetting read/write patterns\n- Saying cache or microservices without explaining why",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Jumping to tools before requirements\n- Making version one too complex\n- Ignoring failure modes\n- Forgetting read/write patterns\n- Saying cache or microservices without explaining why",
      "lineHeight": 1.25,
      "baseline": 96
    },
