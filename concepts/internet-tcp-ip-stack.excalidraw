      "versionNonce": 1262018,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "One-line idea",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "One-line idea",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1260019",
      "type": "text",
      "x": 119,
      "y": 486,
      "width": 612,
      "height": 159,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1260001",
      "roundness": null,
      "seed": 1261019,
      "version": 1,
      "versionNonce": 1262019,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "The TCP/IP stack is a layered model\nfor Internet communication.\n\nEach layer has one job, adds its\nown header, and depends on the\nlayer below it.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The TCP/IP stack is a layered model\nfor Internet communication.\n\nEach layer has one job, adds its\nown header, and depends on the\nlayer below it.",
      "lineHeight": 1.25,
      "baseline": 154
    },
    {
