      "versionNonce": 1262091,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Where DNS fits",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Where DNS fits",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1260092",
      "type": "text",
      "x": 1079,
      "y": 3116,
      "width": 382,
      "height": 99,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1260003",
      "roundness": null,
      "seed": 1261092,
      "version": 1,
      "versionNonce": 1262092,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "DNS is an application-layer protocol.\nIt maps names like example.com\nto IPs before connection setup.",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "DNS is an application-layer protocol.\nIt maps names like example.com\nto IPs before connection setup.",
      "lineHeight": 1.25,
      "baseline": 94
    },
    {
      "id": "text-1260093",
      "type": "text",
      "x": 95,
      "y": 3435,
      "width": 900,
      "height": 48,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1260004",
      "roundness": null,
      "seed": 1261093,
      "version": 1,
      "versionNonce": 1262093,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "How This Matters In System Design",
      "fontSize": 38,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "How This Matters In System Design",
      "lineHeight": 1.25,
      "baseline": 43
    },
    {
      "id": "text-1260094",
      "type": "text",
      "x": 98,
      "y": 3495,
      "width": 1110,
      "height": 50,
      "angle": 0,
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1260004",
      "roundness": null,
      "seed": 1261094,
      "version": 1,
      "versionNonce": 1262094,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Use the TCP/IP stack to explain bottlenecks, failures, latency,\nand where infrastructure pieces operate.",
      "fontSize": 19,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Use the TCP/IP stack to explain bottlenecks, failures, latency,\nand where infrastructure pieces operate.",
      "lineHeight": 1.25,
      "baseline": 45
    },
