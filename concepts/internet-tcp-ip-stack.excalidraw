      "versionNonce": 1262103,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Application: auth, validation\nTransport: TLS, certificates\nInternet: firewall, IP allowlists\nLink: local network controls\n\nSecurity is multi-layered.",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Application: auth, validation\nTransport: TLS, certificates\nInternet: firewall, IP allowlists\nLink: local network controls\n\nSecurity is multi-layered.",
      "lineHeight": 1.25,
      "baseline": 154
    },
