      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Mental model",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Mental model",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1260022",
      "type": "text",
      "x": 874,
      "y": 486,
      "width": 612,
      "height": 159,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1260001",
      "roundness": null,
      "seed": 1261022,
      "version": 1,
      "versionNonce": 1262022,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Sending data is like mailing a package.\n\nThe app writes the message.\nTCP/UDP chooses the conversation.\nIP chooses the address.\nThe link layer handles the local hop.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Sending data is like mailing a package.\n\nThe app writes the message.\nTCP/UDP chooses the conversation.\nIP chooses the address.\nThe link layer handles the local hop.",
      "lineHeight": 1.25,
      "baseline": 154
    },
    {
      "id": "text-1260023",
      "type": "text",
      "x": 95,
      "y": 730,
      "width": 1250,
      "height": 52,
      "angle": 0,
      "strokeColor": "#2b8a3e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1260001",
      "roundness": null,
      "seed": 1261023,
      "version": 1,
      "versionNonce": 1262023,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Main takeaway: TCP/IP is a stack of application protocols, transport protocols, IP routing,\nand local link delivery working together.",
      "fontSize": 20,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Main takeaway: TCP/IP is a stack of application protocols, transport protocols, IP routing,\nand local link delivery working together.",
      "lineHeight": 1.25,
      "baseline": 47
    },
    {
      "id": "text-1260024",
