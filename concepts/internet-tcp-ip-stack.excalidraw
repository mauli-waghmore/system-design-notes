      "frameId": "frame-1260002",
      "roundness": null,
      "seed": 1261031,
      "version": 1,
      "versionNonce": 1262031,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "End-to-end process communication.\nTCP = reliable stream.\nUDP = datagrams.\nQUIC = UDP-based transport.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "End-to-end process communication.\nTCP = reliable stream.\nUDP = datagrams.\nQUIC = UDP-based transport.",
      "lineHeight": 1.25,
      "baseline": 64
    },
    {
