    {
      "id": "text-1260031",
      "type": "text",
      "x": 119,
      "y": 1476,
      "width": 507,
      "height": 69,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
