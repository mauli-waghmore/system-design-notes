      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Layer-aware debugging",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Layer-aware debugging",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1260097",
      "type": "text",
      "x": 119,
      "y": 3656,
      "width": 382,
      "height": 159,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1260004",
      "roundness": null,
      "seed": 1261097,
      "version": 1,
      "versionNonce": 1262097,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Application: bad API or auth\nTransport: timeout, reset, port\nInternet: routing, IP, firewall\nLink: Wi-Fi, Ethernet, gateway\n\nAsk: which layer is failing?",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Application: bad API or auth\nTransport: timeout, reset, port\nInternet: routing, IP, firewall\nLink: Wi-Fi, Ethernet, gateway\n\nAsk: which layer is failing?",
      "lineHeight": 1.25,
      "baseline": 154
    },
    {
