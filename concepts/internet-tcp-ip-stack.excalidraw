    },
    {
      "id": "text-1260109",
      "type": "text",
      "x": 125,
      "y": 4190,
      "width": 1340,
      "height": 50,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1260004",
      "roundness": null,
      "seed": 1261109,
      "version": 1,
      "versionNonce": 1262109,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "\u201cTCP/IP organizes Internet communication into application, transport, internet, and link layers. HTTP or DNS creates app messages. TCP or UDP moves them between processes. IP routes packets across networks. The link layer moves frames across one local hop.\u201d",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\u201cTCP/IP organizes Internet communication into application, transport, internet, and link layers. HTTP or DNS creates app messages. TCP or UDP moves them between processes. IP routes packets across networks. The link layer moves frames across one local hop.\u201d",
      "lineHeight": 1.25,
      "baseline": 45
    },
    {
      "id": "text-1260110",
      "type": "text",
      "x": 95,
      "y": 4300,
      "width": 1180,
