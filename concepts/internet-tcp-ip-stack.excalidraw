      "locked": false,
      "text": "Layer-aware scaling",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Layer-aware scaling",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1260100",
      "type": "text",
      "x": 599,
      "y": 3656,
      "width": 382,
      "height": 159,
      "angle": 0,
      "strokeColor": "#343a40",
