      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Link layer / Network access",
      "fontSize": 21,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Link layer / Network access",
      "lineHeight": 1.25,
      "baseline": 21.25
    },
    {
      "id": "text-1260037",
      "type": "text",
      "x": 119,
      "y": 1846,
      "width": 507,
      "height": 69,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1260002",
      "roundness": null,
      "seed": 1261037,
      "version": 1,
      "versionNonce": 1262037,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Local delivery over one link:\nEthernet, Wi-Fi, ARP, MAC addresses.\n\nData unit: frame.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Local delivery over one link:\nEthernet, Wi-Fi, ARP, MAC addresses.\n\nData unit: frame.",
      "lineHeight": 1.25,
      "baseline": 64
    },
    {
      "id": "rectangle-1260038",
      "type": "rectangle",
      "x": 760,
