    {
      "id": "text-1260085",
      "type": "text",
      "x": 119,
      "y": 3072,
      "width": 382,
      "height": 27.5,
      "angle": 0,
      "strokeColor": "#9c36b5",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1260003",
      "roundness": null,
      "seed": 1261085,
      "version": 1,
      "versionNonce": 1262085,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "What changes at each hop",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What changes at each hop",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1260086",
      "type": "text",
      "x": 119,
      "y": 3116,
      "width": 382,
      "height": 99,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1260003",
      "roundness": null,
      "seed": 1261086,
      "version": 1,
      "versionNonce": 1262086,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "The IP destination usually stays same.\nThe link-layer frame changes\nat every local hop.\n\nMAC addresses are local.",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The IP destination usually stays same.\nThe link-layer frame changes\nat every local hop.\n\nMAC addresses are local.",
      "lineHeight": 1.25,
      "baseline": 94
    },
    {
      "id": "rectangle-1260087",
      "type": "rectangle",
      "x": 575,
      "y": 3050,
      "width": 430,
      "height": 185,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#ebfbee",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1260003",
      "roundness": {
        "type": 3
      },
      "seed": 1261087,
      "version": 1,
      "versionNonce": 1262087,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false
    },
    {
      "id": "text-1260088",
      "type": "text",
      "x": 599,
      "y": 3072,
      "width": 382,
      "height": 27.5,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1260003",
      "roundness": null,
      "seed": 1261088,
      "version": 1,
      "versionNonce": 1262088,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "TCP vs UDP",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "TCP vs UDP",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1260089",
      "type": "text",
      "x": 599,
      "y": 3116,
      "width": 382,
      "height": 99,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1260003",
      "roundness": null,
      "seed": 1261089,
      "version": 1,
      "versionNonce": 1262089,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "TCP tracks order, retries,\nand congestion.\n\nUDP is simpler. Apps add\nreliability when needed.",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "TCP tracks order, retries,\nand congestion.\n\nUDP is simpler. Apps add\nreliability when needed.",
      "lineHeight": 1.25,
      "baseline": 94
    },
    {
      "id": "rectangle-1260090",
      "type": "rectangle",
      "x": 1055,
      "y": 3050,
      "width": 430,
      "height": 185,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#e7f5ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1260003",
      "roundness": {
        "type": 3
      },
      "seed": 1261090,
      "version": 1,
      "versionNonce": 1262090,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false
    },
    {
      "id": "text-1260091",
      "type": "text",
      "x": 1079,
      "y": 3072,
      "width": 382,
      "height": 27.5,
      "angle": 0,
      "strokeColor": "#1971c2",
