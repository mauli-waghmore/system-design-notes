      "updated": 0,
      "link": null,
      "locked": false,
      "text": "TCP/IP vs OSI",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "TCP/IP vs OSI",
      "lineHeight": 1.25,
      "baseline": 23
    },
    {
      "id": "text-1260106",
      "type": "text",
      "x": 125,
      "y": 3975,
      "width": 1340,
      "height": 64,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1260004",
      "roundness": null,
      "seed": 1261106,
      "version": 1,
      "versionNonce": 1262106,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "OSI has 7 layers for teaching and vendor-neutral discussion. TCP/IP is the practical Internet stack.\nOSI presentation/session ideas usually live inside the TCP/IP application layer.\nThe link layer may be shown with or without physical.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "OSI has 7 layers for teaching and vendor-neutral discussion. TCP/IP is the practical Internet stack.\nOSI presentation/session ideas usually live inside the TCP/IP application layer.\nThe link layer may be shown with or without physical.",
      "lineHeight": 1.25,
      "baseline": 59
    },
