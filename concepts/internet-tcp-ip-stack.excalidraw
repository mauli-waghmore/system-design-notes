      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "What apps speak:\nHTTP, DNS, SMTP, SSH, TLS.\n\nData unit: message or app data.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What apps speak:\nHTTP, DNS, SMTP, SSH, TLS.\n\nData unit: message or app data.",
