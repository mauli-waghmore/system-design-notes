      "versionNonce": 1262100,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Application: cache, queue, API design\nTransport: pooling, keep-alive\nInternet: routing, anycast, regions\nLink: NIC, bandwidth, packet loss\n\nScale the bottleneck layer.",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Application: cache, queue, API design\nTransport: pooling, keep-alive\nInternet: routing, anycast, regions\nLink: NIC, bandwidth, packet loss\n\nScale the bottleneck layer.",
