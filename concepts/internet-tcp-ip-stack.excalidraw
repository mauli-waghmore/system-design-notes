      "version": 1,
      "versionNonce": 1262034,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Global addressing and routing\nbetween networks.\n\nMain protocol: IP. Helper: ICMP.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Global addressing and routing\nbetween networks.\n\nMain protocol: IP. Helper: ICMP.",
      "lineHeight": 1.25,
      "baseline": 64
    },
    {
      "id": "rectangle-1260035",
