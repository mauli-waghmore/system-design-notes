      "versionNonce": 1262110,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Best answer: name each layer, explain its job, then trace one request from browser to server and back.",
      "fontSize": 19,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Best answer: name each layer, explain its job, then trace one request from browser to server and back.",
