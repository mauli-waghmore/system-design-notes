      "versionNonce": 1262025,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Some courses show five layers by splitting physical from link.\nFor system design, focus on each layer responsibility.",
      "fontSize": 19,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Some courses show five layers by splitting physical from link.\nFor system design, focus on each layer responsibility.",
      "lineHeight": 1.25,
      "baseline": 45
    },
