      "versionNonce": 1042018,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "One-line idea",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "One-line idea",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1040019",
      "type": "text",
      "x": 119,
      "y": 481,
      "width": 612,
      "height": 144,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040001",
      "roundness": null,
      "seed": 1041019,
      "version": 1,
      "versionNonce": 1042019,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "HTTP defines the format of web requests\nand responses.\n\nHTTPS uses the same HTTP messages,\nbut sends them through an encrypted,\nauthenticated TLS connection.",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "HTTP defines the format of web requests\nand responses.\n\nHTTPS uses the same HTTP messages,\nbut sends them through an encrypted,\nauthenticated TLS connection.",
      "lineHeight": 1.25,
      "baseline": 139
    },
