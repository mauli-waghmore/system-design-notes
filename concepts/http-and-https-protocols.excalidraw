      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Interview wording",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Interview wording",
      "lineHeight": 1.25,
      "baseline": 23
    },
    {
      "id": "text-1040104",
      "type": "text",
      "x": 125,
      "y": 4135,
      "width": 1340,
      "height": 44,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040004",
      "roundness": null,
      "seed": 1041104,
      "version": 1,
      "versionNonce": 1042104,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "\u201cHTTP defines request and response behavior: methods, headers, status codes, and body. HTTPS is HTTP sent through TLS, which adds encryption, integrity, and server authentication. In a design, I would use HTTPS at the edge, decide where TLS terminates, and ensure cookies/tokens are protected.\u201d",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\u201cHTTP defines request and response behavior: methods, headers, status codes, and body. HTTPS is HTTP sent through TLS, which adds encryption, integrity, and server authentication. In a design, I would use HTTPS at the edge, decide where TLS terminates, and ensure cookies/tokens are protected.\u201d",
      "lineHeight": 1.25,
      "baseline": 39
    },
    {
      "id": "text-1040105",
      "type": "text",
      "x": 95,
      "y": 4220,
      "width": 1230,
      "height": 25,
      "angle": 0,
      "strokeColor": "#2b8a3e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040004",
      "roundness": null,
      "seed": 1041105,
      "version": 1,
      "versionNonce": 1042105,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Best answer: separate protocol semantics from transport security, then connect both to real system design decisions.",
      "fontSize": 19,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Best answer: separate protocol semantics from transport security, then connect both to real system design decisions.",
      "lineHeight": 1.25,
      "baseline": 20
    },
    {
      "id": "rectangle-1055001",
      "type": "rectangle",
      "x": 95,
      "y": 3710,
      "width": 1425,
      "height": 105,
      "angle": 0,
      "strokeColor": "#5f3dc4",
      "backgroundColor": "#f3f0ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
