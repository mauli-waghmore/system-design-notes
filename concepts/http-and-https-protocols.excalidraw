      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Mental model",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Mental model",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1040022",
      "type": "text",
      "x": 874,
      "y": 481,
      "width": 612,
      "height": 144,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040001",
      "roundness": null,
      "seed": 1041022,
      "version": 1,
      "versionNonce": 1042022,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "HTTP is a postcard: easy to read\nwhile it travels.\n\nHTTPS is a sealed, signed envelope:\nprivate in transit and tied to the\nserver identity.",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "HTTP is a postcard: easy to read\nwhile it travels.\n\nHTTPS is a sealed, signed envelope:\nprivate in transit and tied to the\nserver identity.",
      "lineHeight": 1.25,
      "baseline": 139
    },
    {
      "id": "text-1040023",
      "type": "text",
      "x": 95,
      "y": 710,
      "width": 1350,
      "height": 52,
      "angle": 0,
      "strokeColor": "#2b8a3e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040001",
      "roundness": null,
      "seed": 1041023,
      "version": 1,
      "versionNonce": 1042023,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Main takeaway: HTTPS does not replace HTTP semantics. It secures the transport so requests, responses, cookies, and tokens are not exposed on the network.",
      "fontSize": 20,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Main takeaway: HTTPS does not replace HTTP semantics. It secures the transport so requests, responses, cookies, and tokens are not exposed on the network.",
      "lineHeight": 1.25,
      "baseline": 47
    },
    {
      "id": "text-1040024",
