      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Common HTTP design choices",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Common HTTP design choices",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1040081",
      "type": "text",
      "x": 119,
      "y": 3511,
      "width": 397,
      "height": 144,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040004",
      "roundness": null,
      "seed": 1041081,
      "version": 1,
      "versionNonce": 1042081,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "- Choose methods carefully\n- Use status codes consistently\n- Design idempotent retries\n- Use pagination for large reads\n- Add timeouts and rate limits",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Choose methods carefully\n- Use status codes consistently\n- Design idempotent retries\n- Use pagination for large reads\n- Add timeouts and rate limits",
      "lineHeight": 1.25,
      "baseline": 139
    },
