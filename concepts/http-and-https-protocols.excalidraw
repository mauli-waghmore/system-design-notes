      "version": 1,
      "versionNonce": 1042025,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "HTTP is stateless: each request should contain enough context for the server to understand it.",
      "fontSize": 19,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "HTTP is stateless: each request should contain enough context for the server to understand it.",
