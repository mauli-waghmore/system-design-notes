    },
    {
      "id": "text-1040068",
      "type": "text",
      "x": 119,
      "y": 2802,
      "width": 382,
      "height": 27.5,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040003",
      "roundness": null,
      "seed": 1041068,
      "version": 1,
      "versionNonce": 1042068,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "What TLS gives you",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What TLS gives you",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1040069",
      "type": "text",
      "x": 119,
      "y": 2846,
      "width": 382,
      "height": 124,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040003",
      "roundness": null,
      "seed": 1041069,
      "version": 1,
      "versionNonce": 1042069,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Confidentiality:\nothers cannot read the traffic.\n\nIntegrity:\ntraffic cannot be silently changed.\n\nAuthentication:\nthe server proves its identity.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Confidentiality:\nothers cannot read the traffic.\n\nIntegrity:\ntraffic cannot be silently changed.\n\nAuthentication:\nthe server proves its identity.",
      "lineHeight": 1.25,
      "baseline": 119
    },
    {
      "id": "rectangle-1040070",
      "type": "rectangle",
      "x": 575,
      "y": 2780,
      "width": 430,
      "height": 210,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#e7f5ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040003",
      "roundness": {
        "type": 3
      },
      "seed": 1041070,
      "version": 1,
      "versionNonce": 1042070,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false
    },
    {
      "id": "text-1040071",
      "type": "text",
      "x": 599,
      "y": 2802,
      "width": 382,
      "height": 27.5,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040003",
      "roundness": null,
      "seed": 1041071,
      "version": 1,
      "versionNonce": 1042071,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "What certificates do",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What certificates do",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1040072",
      "type": "text",
      "x": 599,
      "y": 2846,
      "width": 382,
      "height": 124,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040003",
      "roundness": null,
      "seed": 1041072,
      "version": 1,
      "versionNonce": 1042072,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "A certificate binds a domain name\nto a public key.\n\nThe browser verifies the chain\nagainst trusted certificate\nauthorities.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A certificate binds a domain name\nto a public key.\n\nThe browser verifies the chain\nagainst trusted certificate\nauthorities.",
      "lineHeight": 1.25,
      "baseline": 119
    },
    {
      "id": "rectangle-1040073",
      "type": "rectangle",
      "x": 1055,
      "y": 2780,
      "width": 430,
      "height": 210,
      "angle": 0,
      "strokeColor": "#c92a2a",
      "backgroundColor": "#fff5f5",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040003",
      "roundness": {
        "type": 3
      },
      "seed": 1041073,
      "version": 1,
      "versionNonce": 1042073,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false
    },
    {
      "id": "text-1040074",
      "type": "text",
      "x": 1079,
      "y": 2802,
      "width": 382,
      "height": 27.5,
      "angle": 0,
      "strokeColor": "#c92a2a",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040003",
      "roundness": null,
      "seed": 1041074,
      "version": 1,
      "versionNonce": 1042074,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "What HTTPS does not solve",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What HTTPS does not solve",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1040075",
      "type": "text",
      "x": 1079,
      "y": 2846,
      "width": 382,
      "height": 124,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040003",
      "roundness": null,
      "seed": 1041075,
      "version": 1,
      "versionNonce": 1042075,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "It does not fix bad authorization,\nweak passwords, leaked tokens,\nSQL injection, or unsafe server code.\n\nIt secures data in transit.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It does not fix bad authorization,\nweak passwords, leaked tokens,\nSQL injection, or unsafe server code.\n\nIt secures data in transit.",
      "lineHeight": 1.25,
      "baseline": 119
    },
    {
      "id": "text-1040076",
      "type": "text",
      "x": 95,
      "y": 3060,
      "width": 1290,
      "height": 26,
      "angle": 0,
      "strokeColor": "#2b8a3e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040003",
      "roundness": null,
      "seed": 1041076,
      "version": 1,
      "versionNonce": 1042076,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Rule of thumb: use HTTPS everywhere, especially for login, cookies, APIs, payments, internal service calls, and admin tools.",
      "fontSize": 20,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Rule of thumb: use HTTPS everywhere, especially for login, cookies, APIs, payments, internal service calls, and admin tools.",
      "lineHeight": 1.25,
      "baseline": 21
    },
    {
      "id": "text-1040077",
      "type": "text",
      "x": 95,
      "y": 3295,
      "width": 900,
      "height": 48,
