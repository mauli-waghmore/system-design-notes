      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Common HTTPS design choices",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Common HTTPS design choices",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1040084",
      "type": "text",
      "x": 609,
      "y": 3511,
      "width": 397,
      "height": 144,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040004",
      "roundness": null,
      "seed": 1041084,
      "version": 1,
      "versionNonce": 1042084,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "- Redirect HTTP to HTTPS\n- Set Secure and HttpOnly cookies\n- Use HSTS for browsers\n- Rotate certificates before expiry\n- Encrypt internal traffic when needed",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Redirect HTTP to HTTPS\n- Set Secure and HttpOnly cookies\n- Use HSTS for browsers\n- Rotate certificates before expiry\n- Encrypt internal traffic when needed",
      "lineHeight": 1.25,
      "baseline": 139
    },
