      "updated": 0,
      "link": null,
      "locked": false,
      "text": "HTTP: Request and Response",
      "fontSize": 40,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "HTTP: Request and Response",
      "lineHeight": 1.25,
      "baseline": 45
    },
    {
      "id": "text-1040025",
      "type": "text",
