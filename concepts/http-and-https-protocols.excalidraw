      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Where TLS terminates",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Where TLS terminates",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1040087",
      "type": "text",
      "x": 1099,
      "y": 3511,
      "width": 397,
      "height": 144,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040004",
      "roundness": null,
      "seed": 1041087,
      "version": 1,
      "versionNonce": 1042087,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "TLS often terminates at a load balancer,\nAPI gateway, CDN, or reverse proxy.\n\nThen traffic may continue inside the\nnetwork as HTTP or re-encrypted HTTPS.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "TLS often terminates at a load balancer,\nAPI gateway, CDN, or reverse proxy.\n\nThen traffic may continue inside the\nnetwork as HTTP or re-encrypted HTTPS.",
      "lineHeight": 1.25,
      "baseline": 139
    },
