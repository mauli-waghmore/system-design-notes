      "versionNonce": 1042045,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Stateless means",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Stateless means",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1040046",
      "type": "text",
      "x": 1099,
      "y": 1711,
      "width": 397,
      "height": 135,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040002",
      "roundness": null,
      "seed": 1041046,
      "version": 1,
      "versionNonce": 1042046,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "The server does not automatically\nremember previous requests.\n\nState usually lives in cookies,\nsessions, tokens, databases, or caches.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The server does not automatically\nremember previous requests.\n\nState usually lives in cookies,\nsessions, tokens, databases, or caches.",
      "lineHeight": 1.25,
      "baseline": 89
    },
    {
      "id": "text-1040047",
      "type": "text",
      "x": 95,
      "y": 1905,
      "width": 1280,
      "height": 50,
      "angle": 0,
      "strokeColor": "#2b8a3e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040002",
      "roundness": null,
      "seed": 1041047,
      "version": 1,
      "versionNonce": 1042047,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Important: HTTP can run over TCP directly, or as HTTP/3 over QUIC.\nThe protocol still describes request/response semantics.",
      "fontSize": 19,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Important: HTTP can run over TCP directly, or as HTTP/3 over QUIC.\nThe protocol still describes request/response semantics.",
      "lineHeight": 1.25,
      "baseline": 20
    },
    {
      "id": "text-1040048",
      "type": "text",
      "x": 95,
      "y": 2235,
      "width": 680,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040003",
      "roundness": null,
      "seed": 1041048,
      "version": 1,
      "versionNonce": 1042048,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "HTTPS: HTTP Over TLS",
      "fontSize": 40,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "HTTPS: HTTP Over TLS",
      "lineHeight": 1.25,
      "baseline": 45
    },
    {
      "id": "text-1040049",
      "type": "text",
      "x": 98,
      "y": 2300,
      "width": 1050,
      "height": 25,
      "angle": 0,
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040003",
      "roundness": null,
      "seed": 1041049,
      "version": 1,
      "versionNonce": 1042049,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "HTTPS protects web traffic against passive reading and active tampering on the network.",
      "fontSize": 19,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "HTTPS protects web traffic against passive reading and active tampering on the network.",
