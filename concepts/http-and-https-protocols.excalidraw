      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Android cleartext traffic",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Android cleartext traffic",
      "lineHeight": 1.25,
      "baseline": 23
    },
    {
      "id": "text-1055003",
      "type": "text",
      "x": 125,
      "y": 3770,
      "width": 1340,
      "height": 45,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040004",
      "roundness": null,
      "seed": 1056003,
      "version": 1,
      "versionNonce": 1057003,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "In Android, plain HTTP may be blocked by default for safer apps. If a backend is still HTTP during local/dev testing, the manifest may need android:usesCleartextTraffic=\"true\" or a network security config. For production, prefer HTTPS and keep cleartext disabled.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In Android, plain HTTP may be blocked by default for safer apps. If a backend is still HTTP during local/dev testing, the manifest may need android:usesCleartextTraffic=\"true\" or a network security config. For production, prefer HTTPS and keep cleartext disabled.",
      "lineHeight": 1.25,
      "baseline": 40
    }
  ],
