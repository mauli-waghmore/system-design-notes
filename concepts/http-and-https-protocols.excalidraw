      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "In interviews, explain where HTTP semantics matter and where HTTPS/TLS termination happens.",
      "fontSize": 19,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In interviews, explain where HTTP semantics matter and where HTTPS/TLS termination happens.",
