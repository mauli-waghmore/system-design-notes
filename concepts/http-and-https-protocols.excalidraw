    {
      "id": "text-1040006",
      "type": "text",
      "x": 98,
      "y": 165,
      "width": 960,
      "height": 48,
      "angle": 0,
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1040001",
      "roundness": null,
      "seed": 1041006,
      "version": 1,
      "versionNonce": 1042006,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "HTTP is how browsers and services exchange web messages.\nHTTPS is HTTP protected by TLS encryption and certificate-based identity.",
      "fontSize": 19,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "HTTP is how browsers and services exchange web messages.\nHTTPS is HTTP protected by TLS encryption and certificate-based identity.",
      "lineHeight": 1.25,
      "baseline": 43
    },
