      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "3. DNS lookup",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "3. DNS lookup",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1360034",
      "type": "text",
      "x": 1079,
      "y": 1291,
      "width": 382,
      "height": 134,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1360002",
      "roundness": null,
      "seed": 1361034,
      "version": 1,
      "versionNonce": 1362034,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "If no cached IP exists, a resolver\nfinds an address.\n\nIt may ask root, TLD, and\nauthoritative name servers.\n\nResult: IP address + TTL.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If no cached IP exists, a resolver\nfinds an address.\n\nIt may ask root, TLD, and\nauthoritative name servers.\n\nResult: IP address + TTL.",
      "lineHeight": 1.25,
      "baseline": 129
    },
