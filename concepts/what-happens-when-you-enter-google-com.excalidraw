      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "One-line idea",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "One-line idea",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1360019",
      "type": "text",
      "x": 119,
      "y": 501,
      "width": 612,
      "height": 159,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1360001",
      "roundness": null,
      "seed": 1361019,
      "version": 1,
      "versionNonce": 1362019,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Entering google.com triggers a chain:\nparse the URL, find an IP address,\nconnect securely, send an HTTP request,\nreceive content, then render the page.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Entering google.com triggers a chain:\nparse the URL, find an IP address,\nconnect securely, send an HTTP request,\nreceive content, then render the page.",
      "lineHeight": 1.25,
      "baseline": 154
    },
