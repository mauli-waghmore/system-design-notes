      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "System design improvements",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "System design improvements",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1360119",
      "type": "text",
      "x": 1079,
      "y": 3931,
      "width": 382,
      "height": 134,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1360004",
      "roundness": null,
      "seed": 1361119,
      "version": 1,
      "versionNonce": 1362119,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Use CDN and edge caching\nReuse connections\nCompress responses\nReduce JS and image size\nCache APIs carefully\nMonitor each stage separately",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Use CDN and edge caching\nReuse connections\nCompress responses\nReduce JS and image size\nCache APIs carefully\nMonitor each stage separately",
      "lineHeight": 1.25,
      "baseline": 129
    },
