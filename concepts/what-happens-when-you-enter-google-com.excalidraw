      "versionNonce": 1362101,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "The first response is usually not the whole page. The browser parses it and discovers more work.",
      "fontSize": 19,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The first response is usually not the whole page. The browser parses it and discovers more work.",
