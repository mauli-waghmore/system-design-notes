      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Where failures show up",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Where failures show up",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1360113",
      "type": "text",
      "x": 119,
      "y": 3931,
      "width": 382,
      "height": 134,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1360004",
      "roundness": null,
      "seed": 1361113,
      "version": 1,
      "versionNonce": 1362113,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "DNS issue: site cannot be found\nTCP/TLS issue: connection fails\nHTTP issue: 4xx/5xx response\nBackend issue: slow or wrong data\nRender issue: blank or broken UI",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "DNS issue: site cannot be found\nTCP/TLS issue: connection fails\nHTTP issue: 4xx/5xx response\nBackend issue: slow or wrong data\nRender issue: blank or broken UI",
      "lineHeight": 1.25,
      "baseline": 129
    },
    {
