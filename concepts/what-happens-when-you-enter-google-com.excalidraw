      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "More requests happen",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "More requests happen",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1360107",
      "type": "text",
      "x": 599,
      "y": 3631,
      "width": 382,
      "height": 144,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1360004",
      "roundness": null,
      "seed": 1361107,
      "version": 1,
      "versionNonce": 1362107,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "HTML references extra resources:\n- CSS files\n- JavaScript bundles\n- images and fonts\n- analytics or API calls\n\nEach hostname may need DNS/connect.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "HTML references extra resources:\n- CSS files\n- JavaScript bundles\n- images and fonts\n- analytics or API calls\n\nEach hostname may need DNS/connect.",
      "lineHeight": 1.25,
      "baseline": 139
    },
