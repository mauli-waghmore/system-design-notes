      "groupIds": [],
      "frameId": "frame-1360002",
      "roundness": null,
      "seed": 1361052,
      "version": 1,
      "versionNonce": 1362052,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "4. TCP connection",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "4. TCP connection",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1360053",
      "type": "text",
      "x": 119,
      "y": 1756,
      "width": 382,
      "height": 144,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1360002",
      "roundness": null,
      "seed": 1361053,
      "version": 1,
      "versionNonce": 1362053,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "For HTTPS over TCP, the browser\nopens a TCP connection.\n\nThree-way handshake:\nSYN -> SYN-ACK -> ACK\n\nThis gives reliable, ordered bytes.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "For HTTPS over TCP, the browser\nopens a TCP connection.\n\nThree-way handshake:\nSYN -> SYN-ACK -> ACK\n\nThis gives reliable, ordered bytes.",
      "lineHeight": 1.25,
      "baseline": 139
    },
    {
      "id": "rectangle-1360054",
      "type": "rectangle",
      "x": 575,
      "y": 1690,
      "width": 430,
      "height": 230,
      "angle": 0,
      "strokeColor": "#5f3dc4",
      "backgroundColor": "#f3f0ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1360002",
      "roundness": {
        "type": 3
      },
      "seed": 1361054,
      "version": 1,
      "versionNonce": 1362054,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false
    },
    {
      "id": "text-1360055",
      "type": "text",
      "x": 599,
      "y": 1712,
      "width": 382,
      "height": 27.5,
      "angle": 0,
      "strokeColor": "#5f3dc4",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1360002",
      "roundness": null,
      "seed": 1361055,
      "version": 1,
      "versionNonce": 1362055,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "5. TLS handshake",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "5. TLS handshake",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1360056",
      "type": "text",
      "x": 599,
      "y": 1756,
      "width": 382,
      "height": 144,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1360002",
      "roundness": null,
      "seed": 1361056,
      "version": 1,
      "versionNonce": 1362056,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "HTTPS adds TLS.\n\nThe browser verifies certificate,\nagrees on encryption keys, and\nprotects future traffic from reading\nor tampering.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "HTTPS adds TLS.\n\nThe browser verifies certificate,\nagrees on encryption keys, and\nprotects future traffic from reading\nor tampering.",
      "lineHeight": 1.25,
      "baseline": 139
    },
    {
      "id": "rectangle-1360057",
      "type": "rectangle",
      "x": 1055,
      "y": 1690,
      "width": 430,
      "height": 230,
      "angle": 0,
      "strokeColor": "#0b7285",
      "backgroundColor": "#e3fafc",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1360002",
      "roundness": {
        "type": 3
      },
      "seed": 1361057,
      "version": 1,
      "versionNonce": 1362057,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false
    },
    {
      "id": "text-1360058",
      "type": "text",
      "x": 1079,
      "y": 1712,
      "width": 382,
      "height": 27.5,
      "angle": 0,
      "strokeColor": "#0b7285",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1360002",
      "roundness": null,
      "seed": 1361058,
      "version": 1,
      "versionNonce": 1362058,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Modern note",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Modern note",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1360059",
      "type": "text",
      "x": 1079,
      "y": 1756,
      "width": 382,
      "height": 144,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1360002",
      "roundness": null,
      "seed": 1361059,
      "version": 1,
      "versionNonce": 1362059,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "With HTTP/3, QUIC runs over UDP\nand combines transport + TLS ideas.\n\nThe high-level story is same:\nresolve, connect securely, request.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "With HTTP/3, QUIC runs over UDP\nand combines transport + TLS ideas.\n\nThe high-level story is same:\nresolve, connect securely, request.",
      "lineHeight": 1.25,
      "baseline": 139
    },
    {
      "id": "text-1360060",
      "type": "text",
      "x": 95,
      "y": 1980,
      "width": 1350,
      "height": 25,
      "angle": 0,
      "strokeColor": "#2b8a3e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1360002",
      "roundness": null,
      "seed": 1361060,
      "version": 1,
      "versionNonce": 1362060,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Performance lens: DNS, TCP, and TLS each add latency. Caching, connection reuse, HTTP/2, HTTP/3, and nearby edge servers reduce that cost.",
      "fontSize": 19,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Performance lens: DNS, TCP, and TLS each add latency. Caching, connection reuse, HTTP/2, HTTP/3, and nearby edge servers reduce that cost.",
      "lineHeight": 1.25,
      "baseline": 20
    },
    {
      "id": "text-1360061",
      "type": "text",
      "x": 95,
      "y": 2235,
      "width": 980,
      "height": 48,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1360003",
      "roundness": null,
      "seed": 1361061,
      "version": 1,
      "versionNonce": 1362061,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Step 2: Send The Request, Get The Response",
      "fontSize": 38,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Step 2: Send The Request, Get The Response",
      "lineHeight": 1.25,
      "baseline": 43
    },
    {
      "id": "text-1360062",
      "type": "text",
      "x": 98,
      "y": 2295,
      "width": 980,
      "height": 25,
      "angle": 0,
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1360003",
      "roundness": null,
      "seed": 1361062,
      "version": 1,
      "versionNonce": 1362062,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Once the secure connection exists, HTTP request/response semantics take over.",
      "fontSize": 19,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Once the secure connection exists, HTTP request/response semantics take over.",
      "lineHeight": 1.25,
      "baseline": 20
    },
