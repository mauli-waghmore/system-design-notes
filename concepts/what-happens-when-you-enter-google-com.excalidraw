      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Caching matters",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Caching matters",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1360110",
      "type": "text",
      "x": 1079,
      "y": 3631,
      "width": 382,
      "height": 144,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1360004",
      "roundness": null,
      "seed": 1361110,
      "version": 1,
      "versionNonce": 1362110,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Caching can avoid repeated work:\n- DNS cache\n- HTTP cache\n- CDN cache\n- service worker cache\n- connection reuse\n\nThis makes repeat visits faster.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Caching can avoid repeated work:\n- DNS cache\n- HTTP cache\n- CDN cache\n- service worker cache\n- connection reuse\n\nThis makes repeat visits faster.",
      "lineHeight": 1.25,
      "baseline": 139
    },
    {
