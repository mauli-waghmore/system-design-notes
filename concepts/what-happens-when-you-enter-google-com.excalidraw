      "updated": 0,
      "link": null,
      "locked": false,
      "text": "1. Parse the URL",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Parse the URL",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1360028",
      "type": "text",
      "x": 119,
      "y": 1291,
      "width": 382,
      "height": 134,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1360002",
      "roundness": null,
      "seed": 1361028,
      "version": 1,
      "versionNonce": 1362028,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Browser normalizes the input.\n\nIf you type google.com, the browser\ncan infer https://google.com/.\n\nIt identifies scheme, host, path,\nport, query, and fragment.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Browser normalizes the input.\n\nIf you type google.com, the browser\ncan infer https://google.com/.\n\nIt identifies scheme, host, path,\nport, query, and fragment.",
      "lineHeight": 1.25,
      "baseline": 129
    },
    {
