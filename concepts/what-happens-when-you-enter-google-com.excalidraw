      "versionNonce": 1362115,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Where latency comes from",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Where latency comes from",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1360116",
      "type": "text",
      "x": 599,
      "y": 3931,
      "width": 382,
      "height": 134,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1360004",
      "roundness": null,
      "seed": 1361116,
      "version": 1,
      "versionNonce": 1362116,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "DNS lookup time\nTCP + TLS handshakes\nServer processing time\nNetwork download time\nJavaScript execution\nRendering and layout",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "DNS lookup time\nTCP + TLS handshakes\nServer processing time\nNetwork download time\nJavaScript execution\nRendering and layout",
      "lineHeight": 1.25,
      "baseline": 129
    },
    {
