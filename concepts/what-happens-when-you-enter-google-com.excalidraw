      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Before an HTTP request can be sent, the browser must identify the destination and establish a connection.",
      "fontSize": 19,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Before an HTTP request can be sent, the browser must identify the destination and establish a connection.",
