      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Mental model",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Mental model",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1360022",
      "type": "text",
      "x": 874,
      "y": 501,
      "width": 612,
      "height": 159,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1360001",
      "roundness": null,
      "seed": 1361022,
      "version": 1,
      "versionNonce": 1362022,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "The browser is a coordinator.\n\nIt asks DNS \u201cwhere is Google?\u201d,\nopens a secure network path,\nrequests the page, then turns\nHTML/CSS/JS into pixels.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The browser is a coordinator.\n\nIt asks DNS \u201cwhere is Google?\u201d,\nopens a secure network path,\nrequests the page, then turns\nHTML/CSS/JS into pixels.",
      "lineHeight": 1.25,
      "baseline": 154
    },
    {
      "id": "text-1360023",
      "type": "text",
      "x": 95,
      "y": 750,
      "width": 1370,
      "height": 52,
      "angle": 0,
      "strokeColor": "#2b8a3e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1360001",
      "roundness": null,
      "seed": 1361023,
      "version": 1,
      "versionNonce": 1362023,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Main takeaway: a simple address bar action crosses multiple systems: browser, OS, DNS resolvers, routers, CDNs, load balancers, web servers, and rendering engines.",
      "fontSize": 20,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Main takeaway: a simple address bar action crosses multiple systems: browser, OS, DNS resolvers, routers, CDNs, load balancers, web servers, and rendering engines.",
      "lineHeight": 1.25,
      "baseline": 47
    },
    {
