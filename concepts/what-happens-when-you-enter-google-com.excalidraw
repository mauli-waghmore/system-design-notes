      "versionNonce": 1362104,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "- Parse HTML into DOM\n- Parse CSS into CSSOM\n- Build render tree\n- Layout element positions\n- Paint pixels\n- Run JavaScript when needed",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Parse HTML into DOM\n- Parse CSS into CSSOM\n- Build render tree\n- Layout element positions\n- Paint pixels\n- Run JavaScript when needed",
