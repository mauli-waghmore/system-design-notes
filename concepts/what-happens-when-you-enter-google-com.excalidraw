      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "2. Check caches",
      "fontSize": 22,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "2. Check caches",
      "lineHeight": 1.25,
      "baseline": 22.5
    },
    {
      "id": "text-1360031",
      "type": "text",
      "x": 599,
      "y": 1291,
      "width": 382,
      "height": 134,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame-1360002",
      "roundness": null,
      "seed": 1361031,
      "version": 1,
      "versionNonce": 1362031,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Fast path first:\n- browser DNS cache\n- OS DNS cache\n- router / ISP cache\n- HTTP cache or service worker\n\nIf cached, skip network work.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Fast path first:\n- browser DNS cache\n- OS DNS cache\n- router / ISP cache\n- HTTP cache or service worker\n\nIf cached, skip network work.",
      "lineHeight": 1.25,
      "baseline": 129
    },
    {
