      "versionNonce": 1362099,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "The response has a status code such as 200, 301, 404, or 500, headers like Cache-Control and Content-Type, and a body such as HTML, JSON, images, CSS, or JavaScript.",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The response has a status code such as 200, 301, 404, or 500, headers like Cache-Control and Content-Type, and a body such as HTML, JSON, images, CSS, or JavaScript.",
      "lineHeight": 1.25,
      "baseline": 31
    },
